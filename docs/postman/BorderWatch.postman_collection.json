{
  "info": {
    "name": "BorderWatch API Tests",
    "description": "Postman collection for validating BorderWatch gateway, authentication, telemetry ingestion, tracking, compliance, and role-based access control.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      { "key": "token", "value": "{{accessToken}}", "type": "string" }
    ]
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "pm.variables.set('runId', Date.now());"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "01 - Gateway Health",
      "item": [
        {
          "name": "Gateway health returns ok",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/health"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('response is JSON', () => pm.response.to.be.withBody);",
                  "const body = pm.response.json();",
                  "pm.test('gateway reports ok', () => pm.expect(body.status).to.eql('ok'));"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "02 - Authentication",
      "item": [
        {
          "name": "Admin login returns JWT",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{adminUsername}}\",\n  \"password\": \"{{adminPassword}}\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/auth/login"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('accessToken exists', () => pm.expect(body.accessToken).to.be.a('string').and.not.empty);",
                  "pm.test('token type is Bearer', () => pm.expect(body.tokenType).to.eql('Bearer'));",
                  "pm.test('admin role returned', () => pm.expect(body.user.role).to.eql('ROLE_ADMIN'));",
                  "pm.environment.set('accessToken', body.accessToken);",
                  "pm.environment.set('adminToken', body.accessToken);",
                  "pm.environment.set('adminUserId', body.user.id);"
                ]
              }
            }
          ]
        },
        {
          "name": "Current user profile works with token",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/v1/auth/me"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('profile username matches admin', () => pm.expect(body.username).to.eql(pm.environment.get('adminUsername')));",
                  "pm.test('profile has role', () => pm.expect(body.role).to.eql('ROLE_ADMIN'));"
                ]
              }
            }
          ]
        },
        {
          "name": "Invalid login is rejected",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{adminUsername}}\",\n  \"password\": \"wrong-password\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/auth/login"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 401', () => pm.response.to.have.status(401));",
                  "const body = pm.response.json();",
                  "pm.test('error message exists', () => pm.expect(body.error).to.be.a('string'));"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "03 - Trucks",
      "item": [
        {
          "name": "List trucks as admin",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/v1/trucks?limit=10&offset=0"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('trucks array exists', () => pm.expect(body.trucks).to.be.an('array'));",
                  "pm.test('count matches array length', () => pm.expect(body.count).to.eql(body.trucks.length));"
                ]
              }
            }
          ]
        },
        {
          "name": "Get seeded truck by truck id",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/v1/trucks/CE-2024-ALPHA"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('correct truck returned', () => pm.expect(body.truck_id).to.eql('CE-2024-ALPHA'));",
                  "pm.test('plate number exists', () => pm.expect(body.plate_number).to.be.a('string'));"
                ]
              }
            }
          ]
        },
        {
          "name": "Register temporary truck as admin",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.environment.set('tempTruckId', `CE-PM-${Date.now()}`);"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 201', () => pm.response.to.have.status(201));",
                  "const body = pm.response.json();",
                  "pm.test('created truck id matches request', () => pm.expect(body.truck_id).to.eql(pm.environment.get('tempTruckId')));",
                  "pm.expect(body.id).to.be.a('string').and.not.empty;"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"truck_id\": \"{{tempTruckId}}\",\n  \"plate_number\": \"PM-{{runId}}\",\n  \"operator_name\": \"Postman Test Logistics\",\n  \"operator_email\": \"postman-test@borderwatch.cm\",\n  \"operator_phone\": \"+237600000000\",\n  \"cargo_type\": \"GENERAL_GOODS\",\n  \"notes\": \"Created by automated Postman API tests\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/trucks"
          }
        },
        {
          "name": "Deactivate temporary truck",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": "{{baseUrl}}/api/v1/trucks/{{tempTruckId}}"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('deactivation message returned', () => pm.expect(body.message).to.include('deactivated'));"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "04 - Telemetry",
      "item": [
        {
          "name": "Submit valid telemetry ping",
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"truck_id\": \"CE-2024-ALPHA\",\n  \"latitude\": 4.9601,\n  \"longitude\": 11.8616,\n  \"speed_kmh\": 72.5,\n  \"heading\": 45.0,\n  \"timestamp\": \"{{$isoTimestamp}}\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/telemetry"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 202', () => pm.response.to.have.status(202));",
                  "const body = pm.response.json();",
                  "pm.test('telemetry accepted', () => pm.expect(body.accepted).to.eql(true));",
                  "pm.test('telemetry id exists', () => pm.expect(body.id).to.be.a('string').and.not.empty);",
                  "pm.environment.set('telemetryId', body.id);"
                ]
              }
            }
          ]
        },
        {
          "name": "Submit batch telemetry",
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": {
              "mode": "raw",
              "raw": "[\n  {\n    \"truck_id\": \"CE-2024-ALPHA\",\n    \"latitude\": 5.9667,\n    \"longitude\": 14.3167,\n    \"speed_kmh\": 65.2,\n    \"heading\": 48\n  },\n  {\n    \"truck_id\": \"CE-2024-BETA\",\n    \"latitude\": 4.3612,\n    \"longitude\": 18.5583,\n    \"speed_kmh\": 58.8,\n    \"heading\": 90\n  }\n]"
            },
            "url": "{{baseUrl}}/api/v1/telemetry/batch"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 202', () => pm.response.to.have.status(202));",
                  "const body = pm.response.json();",
                  "pm.test('accepted count is at least 1', () => pm.expect(body.accepted).to.be.at.least(1));",
                  "pm.test('ids array exists', () => pm.expect(body.ids).to.be.an('array'));"
                ]
              }
            }
          ]
        },
        {
          "name": "Reject invalid latitude",
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"truck_id\": \"CE-2024-ALPHA\",\n  \"latitude\": 120.0,\n  \"longitude\": 11.8616\n}"
            },
            "url": "{{baseUrl}}/api/v1/telemetry"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 400', () => pm.response.to.have.status(400));",
                  "const body = pm.response.json();",
                  "pm.test('validation error mentions latitude', () => pm.expect(body.error.toLowerCase()).to.include('latitude'));"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "05 - Tracking",
      "item": [
        {
          "name": "List legal corridors",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/v1/tracking/corridors"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('corridor list is not empty', () => pm.expect(body).to.be.an('array').and.not.empty);",
                  "pm.test('corridor shape is valid', () => { pm.expect(body[0]).to.have.property('id'); pm.expect(body[0]).to.have.property('toleranceKm'); });"
                ]
              }
            }
          ]
        },
        {
          "name": "Analyze on-route position",
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": { "mode": "raw", "raw": "{\n  \"latitude\": 4.9601,\n  \"longitude\": 11.8616\n}" },
            "url": "{{baseUrl}}/api/v1/tracking/analyze"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('status field exists', () => pm.expect(body.status).to.be.oneOf(['ON_ROUTE','OFF_ROUTE','STATIONARY']));",
                  "pm.test('distance field exists', () => pm.expect(body.minDistanceKm).to.be.a('number'));"
                ]
              }
            }
          ]
        },
        {
          "name": "Analyze off-route position",
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": { "mode": "raw", "raw": "{\n  \"latitude\": 0.4162,\n  \"longitude\": 9.4673\n}" },
            "url": "{{baseUrl}}/api/v1/tracking/analyze"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('off route is detected', () => pm.expect(body.status).to.eql('OFF_ROUTE'));",
                  "pm.test('distance is above zero', () => pm.expect(body.minDistanceKm).to.be.above(0));"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "06 - Compliance",
      "item": [
        {
          "name": "List compliance violations",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/v1/compliance/violations?limit=20&offset=0"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('violations array exists', () => pm.expect(body.violations).to.be.an('array'));",
                  "pm.test('total penalty exists', () => pm.expect(body.totalPenaltyFcfa).to.be.a('number'));",
                  "if (body.violations.length > 0) pm.environment.set('violationId', body.violations[0].id);"
                ]
              }
            }
          ]
        },
        {
          "name": "Get compliance statistics",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/v1/compliance/stats"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('stats response is object', () => pm.expect(body).to.be.an('object'));"
                ]
              }
            }
          ]
        },
        {
          "name": "Get audit chain",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/v1/compliance/chain"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('blocks array exists', () => pm.expect(body.blocks).to.be.an('array'));",
                  "pm.test('total block count exists', () => pm.expect(body.totalBlocks).to.be.a('number'));"
                ]
              }
            }
          ]
        },
        {
          "name": "Verify audit chain",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/v1/compliance/chain/verify"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('verification response has validity field or object result', () => pm.expect(body).to.be.an('object'));"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "07 - Access Control",
      "item": [
        {
          "name": "Officer login returns JWT",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{officerUsername}}\",\n  \"password\": \"{{officerPassword}}\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/auth/login"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('officer role returned', () => pm.expect(body.user.role).to.eql('ROLE_OFFICER'));",
                  "pm.environment.set('officerToken', body.accessToken);"
                ]
              }
            }
          ]
        },
        {
          "name": "Officer cannot list users",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [ { "key": "token", "value": "{{officerToken}}", "type": "string" } ]
            },
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/v1/users"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 403', () => pm.response.to.have.status(403));"
                ]
              }
            }
          ]
        },
        {
          "name": "Admin can list users",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [ { "key": "token", "value": "{{adminToken}}", "type": "string" } ]
            },
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/v1/users"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('users array exists', () => pm.expect(body.users).to.be.an('array'));"
                ]
              }
            }
          ]
        }
      ]
    }
  ]
}